{
  "data": {
    "train_path": "./data/datasets/train_full",
    "validation_paths": {
      "synth": "./data/datasets/validation/synth",
      "polish": "./data/datasets/validation/polish"
    },
    "vocab_name": "bpe3k-splitspaces",
    "image_width": 1050,
    "fixed_image_height": 1485,
    "fixed_image_width": 1050
  },
  "model": {
    "d_model": 512,
    "dim_ff": 1024,
    "num_hidden_layers": 8,
    "num_attn_heads": 8,
    "encoder_model_name_or_path": "weights/fcmae-real-scans/exported_encoder",
    "encoder_provider": "transformers",
    "freeze_encoder_stages": 0,
    "max_image_height": 1485,
    "max_image_width": 1050,
    "max_seq_len": 2048,
    "positional_encoding": "rope"
  },
  "optimizer": {
    "learning_rate": 0.001,
    "encoder_lr_factor": 0.1,
    "weight_decay": 0.01,
    "warmup_steps": 1000,
    "cosine_eta_min_factor": 0.05,
    "lr_scheduler": "cosine",
    "cosine_restart_period": 5000,
    "cosine_restart_mult": 2,
    "layerwise_decay_gamma": 0.8,
    "layerwise_target": "encoder"
  },
  "checkpoint": {
    "dirpath": "weights/GrandStaff/es_polish_v1",
    "filename": "smt-model",
    "run_name": "smt-fcmae-adapt-lr03-nollrd-seq2048",
    "monitor": "val/polish/CER_no_ties_beams",
    "mode": "min",
    "save_last": true,
    "auto_resume": false
  },
  "generation": {
    "strategy": "greedy",
    "num_beams": 1,
    "repetition_penalty": 1.3
  },
  "training": {
    "batch_size": 7,
    "val_batch_size": 12,
    "num_workers": 12,
    "max_epochs": 10,
    "val_check_interval": 1000,
    "limit_val_batches": 1.0,
    "accumulate_grad_batches": 19,
    "freeze_encoder_steps": 2000,
    "progress_train_interval_seconds": 30.0,
    "progress_train_every_n_steps": 50,
    "progress_val_percent_interval": 10,
    "progress_enable_ascii_bar": false,
    "gradient_clip_val": 1.0,
    "gradient_clip_algorithm": "norm",
    "log_example_images": false,
    "compile_model": true,
    "compile_mode": "max-autotune-no-cudagraphs",
    "compute_omr_ned": false,
    "use_grammar_constraints": false,
    "use_spine_structure_constraints": false,
    "use_rhythm_constraints": false,
    "grammar_path": "grammars/kern.gbnf",
    "runaway_guard_enabled": true,
    "runaway_guard_strictness": "moderate",
    "label_smoothing": 0.1,
    "tiered_validation_enabled": true,
    "full_validation_every_n_steps": 5000,
    "frequent_validation_set_names": ["polish"],
    "frequent_validation_subset_sizes": { "synth": 256 },
    "early_stopping_enabled": true,
    "early_stopping_patience": 40,
    "early_stopping_min_delta": 1.0
  }
}
