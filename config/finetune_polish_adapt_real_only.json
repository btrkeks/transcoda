{
  "data": {
    "train_path": "./data/datasets/train_polish_adapt",
    "validation_paths": {
      "polish_dev": "./data/datasets/validation/polish_dev",
      "polish_test": "./data/datasets/validation/polish_test",
      "synth": "./data/datasets/validation/synth"
    },
    "vocab_name": "bpe3k-splitspaces",
    "image_width": 1050,
    "fixed_image_height": 1485,
    "fixed_image_width": 1050
  },
  "model": {
    "d_model": 512,
    "dim_ff": 1024,
    "num_hidden_layers": 8,
    "num_attn_heads": 8,
    "encoder_model_name_or_path": "facebook/convnextv2-tiny-22k-224",
    "encoder_provider": "transformers",
    "freeze_encoder_stages": 0,
    "max_image_height": 1485,
    "max_image_width": 1050,
    "max_seq_len": 2048,
    "positional_encoding": "rope"
  },
  "optimizer": {
    "learning_rate": 0.0001,
    "encoder_lr_factor": 0.3,
    "weight_decay": 0.01,
    "warmup_steps": 200,
    "cosine_eta_min_factor": 0.05,
    "lr_scheduler": "cosine",
    "cosine_restart_period": 5000,
    "cosine_restart_mult": 2
  },
  "checkpoint": {
    "filename": "smt-model-finetune-polish-real-only",
    "monitor": "val/polish_dev/CER_no_ties_beams",
    "mode": "min",
    "save_last": true,
    "auto_resume": true,
    "run_name": "SMT-Finetune-Polish-Adapt-RealOnly",
    "tags": ["finetune", "real-scans", "polish-adapt", "real-only"]
  },
  "generation": {
    "strategy": "greedy"
  },
  "training": {
    "batch_size": 6,
    "val_batch_size": 32,
    "num_workers": 12,
    "max_epochs": 8,
    "val_check_interval": 500,
    "limit_val_batches": 1.0,
    "accumulate_grad_batches": 6,
    "progress_train_interval_seconds": 30.0,
    "progress_train_every_n_steps": 50,
    "progress_val_percent_interval": 10,
    "progress_enable_ascii_bar": false,
    "gradient_clip_val": 1.0,
    "gradient_clip_algorithm": "norm",
    "log_example_images": false,
    "compile_model": true,
    "compile_mode": "max-autotune-no-cudagraphs",
    "compute_omr_ned": false,
    "grammar_path": "grammars/kern.gbnf",
    "runaway_guard_enabled": true,
    "runaway_guard_strictness": "moderate",
    "label_smoothing": 0.1,
    "tiered_validation_enabled": true,
    "full_validation_every_n_steps": 2000,
    "frequent_validation_set_names": ["polish_dev"],
    "early_stopping_enabled": true,
    "early_stopping_patience": 6,
    "early_stopping_min_delta": 0.005
  }
}
