{
  "data": {
    "image_dir": "data/fcmae_images",
    "manifest_path": null,
    "image_height": 1485,
    "image_width": 1050,
    "extensions": [".png", ".jpg", ".jpeg", ".webp"]
  },
  "model": {
    "encoder_model_name_or_path": "facebook/convnextv2-base-22k-224",
    "patch_size": 32,
    "mask_ratio": 0.6,
    "decoder_dim": 512,
    "decoder_depth": 1,
    "norm_pix_loss": true,
    "ink_bias_strength": 0.5,
    "use_foreground_quota_masking": false,
    "foreground_mask_ratio": 0.6,
    "medium_mask_ratio": 0.25,
    "background_mask_ratio": 0.15,
    "ink_loss_weight_alpha": 0.0,
    "ink_loss_weight_target_density": 0.05,
    "ink_aux_loss_weight": 1.0,
    "ink_aux_bce_weight": 0.5,
    "ink_aux_dice_weight": 0.5,
    "ink_aux_target_threshold": 0.05
  },
  "training": {
    "batch_size": 4,
    "num_workers": 8,
    "max_steps": 10000,
    "accumulate_grad_batches": 64,
    "base_learning_rate": 0.00064,
    "weight_decay": 0.05,
    "warmup_steps": 1000,
    "precision": "bf16-mixed",
    "seed": 0,
    "resume_from_checkpoint": null,
    "devices": 1,
    "strategy": "auto",
    "num_nodes": 1
  },
  "checkpoint": {
    "dirpath": "weights/fcmae-real-scans",
    "filename": "fcmae-{step:06d}",
    "save_last": true,
    "save_top_k": -1,
    "every_n_train_steps": 1000
  },
  "logging": {
    "wandb_enabled": true,
    "project": "SMT-FCMAE",
    "run_name": "fcmae-real-scan",
    "group": null,
    "tags": [],
    "log_model": false,
    "log_reconstructions": true,
    "log_reconstruction_every_n_steps": 500,
    "log_reconstruction_max_batches": 80,
    "log_reconstruction_max_images": 4
  },
  "export": {
    "output_dir": null,
    "export_on_train_end": false,
    "overwrite": false,
    "validate_export": true
  }
}
