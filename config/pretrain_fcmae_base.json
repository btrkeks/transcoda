{
  "data": {
    "image_dir": "data/fcmae_images",
    "manifest_path": null,
    "image_height": 1485,
    "image_width": 1050,
    "extensions": [".png", ".jpg", ".jpeg", ".webp"]
  },
  "model": {
    "encoder_model_name_or_path": "facebook/convnextv2-base-22k-224",
    "patch_size": 32,
    "mask_ratio": 0.6,
    "decoder_dim": 512,
    "decoder_depth": 2,
    "norm_pix_loss": false,
    "ink_bias_strength": 0.3
  },
  "training": {
    "batch_size": 4,
    "num_workers": 4,
    "max_steps": 30000,
    "accumulate_grad_batches": 16,
    "base_learning_rate": 0.00064,
    "weight_decay": 0.05,
    "warmup_steps": 1000,
    "precision": "bf16-mixed",
    "seed": 0,
    "resume_from_checkpoint": null
  },
  "checkpoint": {
    "dirpath": "weights/fcmae",
    "filename": "fcmae-{step:06d}",
    "save_last": true,
    "save_top_k": -1,
    "every_n_train_steps": 5000
  },
  "logging": {
    "wandb_enabled": false,
    "project": "SMT-FCMAE",
    "run_name": null,
    "group": null,
    "tags": [],
    "log_model": false,
    "log_reconstructions": true,
    "log_reconstruction_every_n_steps": 500,
    "log_reconstruction_max_batches": 80,
    "log_reconstruction_max_images": 4
  },
  "export": {
    "output_dir": null,
    "export_on_train_end": false,
    "overwrite": false,
    "validate_export": true
  }
}
